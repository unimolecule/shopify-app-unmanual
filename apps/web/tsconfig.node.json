{
  "extends": ["@unconfig/ts-config/node.json"],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist"
  },
  "include": [
    "./configs/**/*",
    "./constants/**/*",
    "./internal/**/*",
    "./scripts/**/*",
    "**/*.config.ts",
    "./package.json"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/tests/**",
    "**/dist/**/*",
    "**/node_modules/**/*",
    "**/*.md"
  ]
}
