{
  "name": "@shamt/web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "author": "i7eo",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --env-file=../../.env.development --import tsx/esm ./node_modules/vite/bin/vite.js",
    "build": "node --env-file=../../.env.production --import tsx/esm ./node_modules/vite/bin/vite.js build",
    "test": "node --env-file=../../.env.development ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node --env-file=../../.env.development ./node_modules/vitest/vitest.mjs run --coverage",
    "test:coverage:view": "open coverage/index.html",
    "format": "prettier \"./**/*.{js,ts,jsx,tsx,md,json,jsonc}\" --write",
    "lint": "TIMING=1 eslint \"./**/*.{js,jsx,ts,tsx,md,json,jsonc}\" --fix",
    "clean": "run-p \"clean:**\"",
    "clean:cache": "rimraf dist",
    "clean:deps": "rimraf node_modules"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@shamt/app-env": "workspace:*",
    "@shamt/database": "workspace:*",
    "@shopify/app-bridge-react": "^4.2.11",
    "@shopify/app-bridge-types": "^0.7.1",
    "@shopify/polaris-types": "^1.0.7",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@unimolecule/oh-my-fetch": "catalog:",
    "@unimolecule/utils": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "catalog:react",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "catalog:tailwindcss",
    "tw-animate-css": "^1.4.0",
    "zod": "catalog:",
    "zustand": "catalog:react"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:tailwindcss",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/react": "catalog:test",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@unconfig/ts-config": "catalog:dx",
    "@vitejs/plugin-react": "catalog:react",
    "@vitest/coverage-v8": "catalog:test",
    "jsdom": "catalog:test",
    "sharp": "^0.35.3",
    "svgo": "^4.0.1",
    "tsx": "catalog:dx",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "catalog:test"
  }
}
