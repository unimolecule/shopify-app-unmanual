{
  "name": "@unimolecule/shopify-app-unmanual-server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "author": "i7eo",
  "license": "MIT",
  "exports": {
    "./app-api-type": {
      "types": "./src/app/bootstrap/app-api-type.ts",
      "import": "./src/app/bootstrap/app-api-type.ts",
      "require": "./src/app/bootstrap/app-api-type.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      "./app-api-type": {
        "types": "./dist/typings/app-api-type.d.mts",
        "import": "./dist/typings/app-api-type.mjs",
        "require": "./dist/typings/app-api-type.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "cf:type": "wrangler types ./typings/cloudflare-worker-configuration.d.ts",
    "cf:dev": "node --env-file=../../.env.development ./node_modules/wrangler/bin/wrangler.js dev --port \"$BACKEND_PORT\" --env development --env-file ../../.env.development --var \"SHOPIFY_APP_URL:${APP_URL:-$HOST}\"",
    "cf:deploy": "node --env-file=../../.env.production --import tsx ./scripts/deploy/cloudflare.ts && wrangler secret bulk ../../.env.production --env production && wrangler deploy --env production",
    "node:dev": "APP__SERVER_PORT=\"$BACKEND_PORT\" SHOPIFY_APP_URL=\"${APP_URL:-$HOST}\" tsx watch --env-file=../../.env.development ./src/app/runtime/process/node/index.ts",
    "node:deploy": "node --env-file=../../.env.production --import tsx ./scripts/deploy/node.ts",
    "bundle": "tsdown --config ./build.config.ts",
    "build": "node --env-file=../../.env.production --run bundle",
    "db:push:pg": "node --env-file=../../.env.development ./node_modules/drizzle-kit/bin.cjs push --config ./drizzle.pg.config.ts",
    "db:push:d1": "node --env-file=../../.env.development ./node_modules/drizzle-kit/bin.cjs push --config ./drizzle.d1.config.ts",
    "db:generate:pg": "drizzle-kit generate --config ./drizzle.pg.generate.config.ts",
    "db:generate:d1": "drizzle-kit generate --config ./drizzle.d1.generate.config.ts",
    "db:migrate:pg": "node --env-file=../../.env.production ./node_modules/drizzle-kit/bin.cjs migrate --config ./drizzle.pg.config.ts",
    "db:migrate:d1": "node --env-file=../../.env.production ./node_modules/wrangler/bin/wrangler.js d1 migrations apply i7eo-shopify-app-d1 --env production --remote",
    "db:seed:dev:pg": "node --env-file=../../.env.development --import tsx ./scripts/database/seed.pg.ts",
    "db:seed:prod:pg": "CONFIRM_PROD_SEED=true node --env-file=../../.env.production --import tsx ./scripts/database/seed.pg.ts",
    "db:seed:dev:d1": "node --env-file=../../.env.development --import tsx ./scripts/database/seed.d1.ts",
    "db:seed:prod:d1": "CONFIRM_PROD_SEED=true D1_WRANGLER_ENV=production node --env-file=../../.env.production --import tsx ./scripts/database/seed.d1.ts",
    "test": "node --env-file=../../.env.development ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node --env-file=../../.env.development ./node_modules/vitest/vitest.mjs run --coverage",
    "test:coverage:view": "open coverage/index.html",
    "format": "prettier \"./**/*.{js,ts,jsx,tsx,md,json,jsonc}\" --write",
    "lint": "TIMING=1 eslint \"./**/*.{js,jsx,ts,tsx,md,json,jsonc}\" --fix",
    "clean": "run-p \"clean:**\"",
    "clean:cache": "rimraf dist",
    "clean:deps": "rimraf node_modules"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@logtape/file": "^2.2.3",
    "@logtape/logtape": "^2.2.3",
    "@scalar/hono-api-reference": "^0.11.8",
    "@shopify/shopify-api": "^13.1.0",
    "@shopify/shopify-app-session-storage": "^5.0.1",
    "@shopify/shopify-app-session-storage-drizzle": "^4.0.1",
    "@unimolecule/canon": "catalog:",
    "@unimolecule/oh-my-fetch": "catalog:",
    "@unimolecule/shopify-app-unmanual-app-env": "workspace:*",
    "@unimolecule/shopify-app-unmanual-database": "workspace:*",
    "@unimolecule/utils": "catalog:",
    "drizzle-orm": "catalog:drizzle",
    "formidable": "^4.0.0-rc.6",
    "hono": "catalog:hono",
    "pg": "catalog:pg",
    "pg-boss": "catalog:queue",
    "redis": "catalog:redis",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@types/node": "catalog:",
    "@types/pg": "catalog:pg",
    "@unconfig/ts-config": "catalog:dx",
    "@vitest/coverage-v8": "catalog:test",
    "drizzle-kit": "catalog:drizzle",
    "tsdown": "catalog:dx",
    "tsx": "catalog:dx",
    "typescript": "catalog:",
    "vitest": "catalog:test",
    "wrangler": "catalog:cloudflare"
  }
}
